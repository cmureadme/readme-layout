        </PAGEOBJECT>
        <PAGEOBJECT XPOS="461.2508" YPOS="995.7548" OwnPage="1" ItemID="512338640" PTYPE="4" WIDTH="239.894" HEIGHT="314.074" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="7.2" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L239.894 0 L239.894 314.074 L0 314.074 L0 0 Z" copath="M0 0 L239.894 0 L239.894 314.074 L0 314.074 L0 0 Z" gXpos="461.2508" gYpos="-1500.24520000001" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="10" FONT="Bell MT Regular" FONTSIZE="9" KERN="0"/>
                <ITEXT FONT="Bell MT Bold" FONTSIZE="9" CH="Auntie Readme"/>
                <para PARENT="Default Paragraph Style" ALIGN="1" LINESP="10"/>
                <ITEXT FONT="Bell MT Italic" FONTSIZE="9" CH="Has a squealing feeling"/>
                <para PARENT="Default Paragraph Style" ALIGN="1" LINESP="10"/>
                <para PARENT="Default Paragraph Style" LINESP="10"/>
                <ITEXT FONT="Bell MT Regular" FONTSIZE="9" CH="    "/>
                <ITEXT FONT="Bell MT Bold" FONTSIZE="9" CH="Feeling Hogtied:"/>
                <ITEXT FONT="Bell MT Regular" FONTSIZE="9" CH=" February is the time for renegotiating leases. And, coincidentally, retreading and regretting my love life. I'm currently living in a two-bedroom with a guy who looks kind of like Timothee Chalamet if he were born and raised in the Texas panhandle. Long story short, we flirted a tiny bit, and he suggested that he was maybe considering possibly buying me flowers at some unspecific point in the future. Didn’t happen."/>
                <para PARENT="Default Paragraph Style" LINESP="10"/>
                <ITEXT FONT="Bell MT Regular" FONTSIZE="9" CH="    I'm looking to find a new place to live, but all the good stuff got snatched up already. My only other option is a one-bedroom shack at the edge of Schenley Park. Now, this would almost certainly be preferable to awkwardly avoiding eye contact with my situationship every time one of us does the dishes or makes food, but the only hiccup is that I'd be sharing the place with the entire hog population of Carnegie Mellon University. What should I do? "/>
                <para PARENT="Default Paragraph Style" LINESP="10"/>
                <ITEXT FONT="Bell MT Regular" FONTSIZE="9" CH="   "/>
                <ITEXT FONT="Bell MT Italic" FONTSIZE="9" CH=" Sincerely, Feeling Hogtied"/>
                <para PARENT="Default Paragraph Style" LINESP="10"/>
                <para PARENT="Default Paragraph Style" LINESP="10"/>
                <ITEXT FONT="Bell MT Regular" FONTSIZE="9" CH="    "/>
                <ITEXT FONT="Bell MT Bold" FONTSIZE="9" CH="Auntie Readme: "/>
                <ITEXT FONT="Bell MT Regular" FONTSIZE="9" CH="Glad to hear from you, Feeling Hogtied. "/>
                <para PARENT="Default Paragraph Style" LINESP="10"/>
                <ITEXT FONT="Bell MT Regular" FONTSIZE="9" CH="    Sounds like you’ve got quite the conundrum on your hands. Most pig-related species I know are enrolled in some Tepper degree, so I’d imagine the social life would be pretty great. On the other hand, hogs can get pretty loud, which is a pretty sharp contrast to the muffled weeping you probably hear late at night through the walls. I guess the question boils down to this: both situations will be annoying to handle, but only one of them will leave you feeling heartbroken. I’d recommend buying an air freshener for your shack, and maybe an extra big drip pan to catch the inevitable bacon grease."/>
                <para PARENT="Default Paragraph Style" LINESP="10"/>
                <para PARENT="Default Paragraph Style" LINESP="10"/>
                <para PARENT="Default Paragraph Style" LINESP="10"/>
                <para PARENT="Default Paragraph Style" LINESP="10"/>
                <para PARENT="Default Paragraph Style" LINESP="10"/>
                <para PARENT="Default Paragraph Style" LINESP="10"/>
                <para PARENT="Default Paragraph Style" LINESP="10"/>
                <para PARENT="Default Paragraph Style" LINESP="10"/>
                <para PARENT="Default Paragraph Style" LINESP="10"/>
                <para PARENT="Default Paragraph Style" LINESP="10"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="466.5288" YPOS="1318.1408" OwnPage="1" ItemID="512344304" PTYPE="2" WIDTH="231.968" HEIGHT="313.48" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="0.14927619047619" LOCALSCY="0.14927619047619" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="0" RATIO="1" Pagenumber="0" PFILE="../../../../../../Downloads/petition.png" IRENDER="0" EMBEDDED="0" path="M0 0 L231.968 0 L231.968 313.48 L0 313.48 L0 0 Z" copath="M0 0 L231.968 0 L231.968 313.48 L0 313.48 L0 0 Z" gXpos="466.5288" gYpos="1318.1408" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="114.2508" YPOS="1794.758" OwnPage="2" ItemID="512375456" PTYPE="4" WIDTH="240.182" HEIGHT="385.218" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="7.2" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L240.182 0 L240.182 385.218 L0 385.218 L0 0 Z" copath="M0 0 L240.182 0 L240.182 385.218 L0 385.218 L0 0 Z" gXpos="114.2508" gYpos="-701.242000000014" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="10" FONT="Bell MT Regular" FONTSIZE="9" KERN="0"/>
                <ITEXT FONT="Bell MT Bold" FONTSIZE="9" CH="Auntie Readme"/>
                <para PARENT="Default Paragraph Style" ALIGN="1" LINESP="10"/>
                <ITEXT FONT="Bell MT Italic" FONTSIZE="9" CH="She’ll be coming ‘round the mountain when she comes"/>
                <para PARENT="Default Paragraph Style" ALIGN="1" LINESP="10"/>
                <para PARENT="Default Paragraph Style" ALIGN="0" LINESP="10"/>
                <ITEXT FONTSIZE="9" CH="    "/>
                <ITEXT FONT="Bell MT Bold" FONTSIZE="9" CH="Free Bird from DC:"/>
                <ITEXT FONTSIZE="9" CH=" Hey Auntie, I think I’ve hit a rough patch in my life. It’s February and all this talk of love and relationships has got me all torn up. See, it's been a rough year. I’ve just been feeling like shit. I keep blowing up at all my friends, friends I've been close with for decades! My deteriorating love life is certainly not helping."/>
                <para/>
                <ITEXT FONTSIZE="9" CH="    Recently I’ve been thinking about my ex. What I see of her life seems so perfect! She broke up with that weird polycule she was a part of and started working on herself. She’s completely changed her political compass and is focusing on her own self improvement. It reminds me so much of when we were together."/>
                <para/>
                <ITEXT FONTSIZE="9" CH="    Now, I know we were far from perfect. I know people thought we were a crazy couple. I told her she was controlling and needed to get off my ass about paying the bills. She made me pay crazy rent, made me tolerate her weird friends, and she did burn all of my shit when we broke up, but nobody’s perfect! People like to mention our age gap, she may be 1099 years old, but I’m 250, it’s all legal! I dumped her (tea in the bay) because I thought I could do better, but now that I’ve amounted to nothing, I see I was wrong."/>
                <para/>
                <ITEXT FONTSIZE="9" CH="    So, should I call her? I really think we could be something again."/>
                <para/>
                <ITEXT FONT="Bell MT Italic" FONTSIZE="9" CH="    Sincerely, Free Bird"/>
                <para/>
                <para/>
                <ITEXT FONTSIZE="9" CH="    "/>
                <ITEXT FONT="Bell MT Bold" FONTSIZE="9" CH="Auntie:"/>
                <ITEXT FONTSIZE="9" CH=" Thank you for writing, Free Bird."/>
                <para/>
                <ITEXT FONTSIZE="9" CH="    It sounds like you’re in quite the situation. To me, it sounds like you have some personal issue to work out before jumping into a relationship. Maybe try addressing some of those inner riots you feel. Then, maybe reconnect with this special someone as a friend. Build up a rapport before trying to pursue something more. Consider an exchange of goods, like jewelry or oil. As you get to know her better again, make sure you declare your independence and set your boundaries from the beginning. Maybe draw up some sort of constitution to establish the expectations of the relationship. Good luck, love!"/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="113.5848" YPOS="1696.69746850394" OwnPage="2" ItemID="512372624" PTYPE="4" WIDTH="240.848" HEIGHT="96.6945314960603" FRTYPE="0" CLIPEDIT="1" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L240.848 0 L240.848 96.6945 L0 96.6945 L0 0 Z" copath="M0 0 L240.848 0 L240.848 96.6949 L0 96.6949 L0 0 Z" gXpos="113.5848" gYpos="864.69746850394" gWidth="282.55" gHeight="45.4146798798563" ALIGN="1" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle ALIGN="1" LINESP="28" FONT="Special Elite Regular" FONTSIZE="33" SCALEH="90" KERN="-11"/>
                <ITEXT KERN="-11" CH="Auntie Readme:"/>
                <para ALIGN="1"/>
                <ITEXT CH="I want to get back with my ex!"/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="117.2508" YPOS="2623.7612" OwnPage="3" ItemID="512378288" PTYPE="4" WIDTH="247.166" HEIGHT="73.8499999999999" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="7.2" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L247.166 0 L247.166 73.85 L0 73.85 L0 0 Z" copath="M0 0 L247.166 0 L247.166 73.85 L0 73.85 L0 0 Z" gXpos="117.2508" gYpos="127.761199999986" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="10" FONT="Bell MT Regular" FONTSIZE="9" KERN="0"/>
                <ITEXT FONT="Bell MT Bold" FONTSIZE="9" CH="Allyn"/>
                <para PARENT="Default Paragraph Style" ALIGN="1" LINESP="10"/>
                <ITEXT FONT="Bell MT Italic" FONTSIZE="9" CH="[REDACTED]"/>
                <para PARENT="Default Paragraph Style" ALIGN="1" LINESP="10"/>
