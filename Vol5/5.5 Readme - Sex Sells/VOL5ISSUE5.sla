        <FRAMEOBJECT InID="28855" XPOS="0" YPOS="0" OwnPage="-1" ItemID="218713920" PTYPE="4" WIDTH="275.04" HEIGHT="181.251968503937" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="7.2" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L275.04 0 L275.04 181.252 L0 181.252 L0 0 Z" copath="M0 0 L275.04 0 L275.04 181.252 L0 181.252 L0 0 Z" isInline="1" gXpos="0" gYpos="0" gWidth="275.04" gHeight="181.251968503937" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="10" FONT="Bell MT Regular" FONTSIZE="9"/>
                <ITEXT FONT="Bell MT Bold" CH="Danya Kogan"/>
                <para ALIGN="1" LINESP="10"/>
                <ITEXT FONT="Bell MT Bold" CH="Anti-Kar Aktion"/>
                <para ALIGN="1" LINESP="10"/>
                <para ALIGN="1" LINESP="10"/>
                <ITEXT FONT="Bell MT Regular" FONTSIZE="9" SCALEH="100" SCALEV="100" CH="    Margaret Morrison Street is a beloved dainty throughway within the confines of Carnegie Mellon University bordered by many residence halls, such as Boss, McGill, Scobell, Welch, Henderson, as well as the biological hazard known as “Donner House”. "/>
                <para/>
                <ITEXT FONT="Bell MT Regular" FONTSIZE="9" SCALEH="100" SCALEV="100" CH="    A safety analysis run by CMU’s highly esteemed professor Dr. Et Al revealed that the curbs contiguous with the sidewalks that barely anyone uses serve as a potential hazard towards automobiles passing through, thus the sidewalks had to go, expanding the road’s shoulder in the process."/>
                <para/>
                <ITEXT FONT="Bell MT Regular" FONTSIZE="9" SCALEH="100" SCALEV="100" CH="    After the university had finished this construction, Dr. Et Al ran a subsequent analysis, this time measuring the road’s level of service. The results were “atrocious”, as the professor said himself. It was obvious what had to happen following this. Carnegie Mellon unveiled its brand new “Margaret Morrison Memorial 30-Lane Highway.” However, more analyses run by the world’s greatest academic suggested that the university has to build more lanes, otherwise the throughway wouldn’t live up to its maximum potential."/>
                <trail/>
            </StoryText>
        </FRAMEOBJECT>
        <FRAMEOBJECT InID="11351" XPOS="0" YPOS="0" OwnPage="-1" ItemID="224038048" PTYPE="4" WIDTH="275.04" HEIGHT="181.251968503937" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="7.2" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L275.04 0 L275.04 181.252 L0 181.252 L0 0 Z" copath="M0 0 L275.04 0 L275.04 181.252 L0 181.252 L0 0 Z" isInline="1" gXpos="0" gYpos="0" gWidth="275.04" gHeight="181.251968503937" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="10" FONT="Bell MT Regular" FONTSIZE="9"/>
                <ITEXT FONT="Bell MT Bold" CH="Danya Kogan"/>
                <para ALIGN="1" LINESP="10"/>
                <ITEXT FONT="Bell MT Bold" CH="Anti-Kar Aktion"/>
                <para ALIGN="1" LINESP="10"/>
                <para ALIGN="1" LINESP="10"/>
                <ITEXT FONT="Bell MT Regular" FONTSIZE="9" SCALEH="100" SCALEV="100" CH="    Margaret Morrison Street is a beloved dainty throughway within the confines of Carnegie Mellon University bordered by many residence halls, such as Boss, McGill, Scobell, Welch, Henderson, as well as the biological hazard known as “Donner House”. "/>
                <para/>
                <ITEXT FONT="Bell MT Regular" FONTSIZE="9" SCALEH="100" SCALEV="100" CH="    A safety analysis run by CMU’s highly esteemed professor Dr. Et Al revealed that the curbs contiguous with the sidewalks that barely anyone uses serve as a potential hazard towards automobiles passing through, thus the sidewalks had to go, expanding the road’s shoulder in the process."/>
                <para/>
                <ITEXT FONT="Bell MT Regular" FONTSIZE="9" SCALEH="100" SCALEV="100" CH="    After the university had finished this construction, Dr. Et Al ran a subsequent analysis, this time measuring the road’s level of service. The results were “atrocious”, as the professor said himself. It was obvious what had to happen following this. Carnegie Mellon unveiled its brand new “Margaret Morrison Memorial 30-Lane Highway.” However, more analyses run by the world’s greatest academic suggested that the university has to build more lanes, otherwise the throughway wouldn’t live up to its maximum potential."/>
                <trail/>
            </StoryText>
        </FRAMEOBJECT>
        <PAGEOBJECT XPOS="375.499914285714" YPOS="3173.9804" OwnPage="3" ItemID="757195776" PTYPE="6" WIDTH="321.205885714285" HEIGHT="118.5992" FRTYPE="0" CLIPEDIT="1" PWIDTH="1.7208" PCOLOR2="Black" PLINEART="1" path="M0 0 L321.206 0 L321.206 118.599 L0 118.599 L0 0 Z" copath="M0 0 L321.206 0 L321.206 118.599 L0 118.599 L0 0 Z" gXpos="375.499914285714" gYpos="3173.9804" gWidth="0" gHeight="0" LAYER="0"/>
        <PAGEOBJECT XPOS="380.3208" YPOS="3177.76" OwnPage="3" ItemID="757170288" PTYPE="4" WIDTH="316.0934" HEIGHT="121.568" FRTYPE="0" CLIPEDIT="1" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L316.093 0 L316.093 121.568 L0 121.568 L0 0 Z" copath="M0 0 L316.095 0 L316.095 121.568 L0 121.568 L0 0 Z" gXpos="722.8488" gYpos="662.8528" gWidth="269.403" gHeight="114.244495412844" ALIGN="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle ALIGN="0" LINESP="9" FONT="Bell MT Regular" FONTSIZE="9"/>
                <ITEXT FONT="Bell MT Regular" FONTSIZE="8" CH="This issue of readme is brought to you by: "/>
                <para ALIGN="0" LINESP="9"/>
                <ITEXT FONT="Bell MT Bold" FONTSIZE="8" CH="Editors:"/>
                <ITEXT FONT="Bell MT Regular" FONTSIZE="8" CH=" "/>
                <ITEXT FONTSIZE="8" CH="Eshaan Joshi, Gilgamesh Ichthyomorphosis, Tali Kirschenbaum, Jupiter, Bertie Wooster, Allyn, Daniel Yin, Violet R. Blu, Spiggy40"/>
                <ITEXT CH=", Citron"/>
                <para ALIGN="0" LINESP="9"/>
                <ITEXT FONT="Bell MT Bold" FONTSIZE="8" CH="Cover Art:"/>
                <ITEXT FONTSIZE="8" CH=" Allyn"/>
                <para ALIGN="0" LINESP="9"/>
